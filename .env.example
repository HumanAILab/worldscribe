# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and must NEVER be committed.

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key

# Azure Speech service credentials (https://portal.azure.com)
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus

# IP of the machine running the visual server
SERVER_IP=127.0.0.1

# Firebase Admin SDK service-account JSON file path.
# Download your own from the Firebase console and place it in the project root.
# The file itself is gitignored.
FIREBASE_CREDENTIALS=firebase-credentials.json

# Firebase Realtime Database URL for your project.
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com/
